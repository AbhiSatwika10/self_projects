{
  "manifest_version": 3,
  "name": "AI Reality Check",
  "version": "2.0",
  "description": "Real-Time AI Trust Scanner",
  "permissions": ["activeTab","scripting"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}